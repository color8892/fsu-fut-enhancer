{
  "name": "fsu-fut-extension",
  "version": "26.9.0",
  "private": true,
  "type": "module",
  "description": "Unpacked Chrome extension wrapper for the FSU EAFC FUT Web userscript.",
  "scripts": {
    "prepare:legacy": "node scripts/prepare-legacy.cjs",
    "build:wasm": "node scripts/build-wasm.cjs",
    "build": "node scripts/build-wasm.cjs && node scripts/build-userscript.cjs",
    "build:watch": "node scripts/build-wasm.cjs && node scripts/build-userscript.cjs --watch",
    "build:userscript": "node scripts/build-userscript.cjs",
    "build:all": "npm run prepare:legacy && npm run build",
    "test": "node tests/run-tests.mjs",
    "test:all": "npm run build && npm test",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.28.0"
  }
}
