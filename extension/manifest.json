{
  "manifest_version": 3,
  "name": "FSU EAFC FUT Web Enhancer",
  "version": "26.9.0",
  "description": "Chrome extension wrapper for the FSU EAFC FUT Web userscript.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.ea.com/*",
    "https://www.easports.com/*",
    "https://www.futbin.com/*",
    "https://www.futbin.org/*",
    "https://www.fut.gg/*",
    "https://www.easysbc.io/*",
    "https://api.fut.to/*",
    "https://enhancer-api.futnext.com/*",
    "https://utas.mob.v5.prd.futc-ext.gcp.ea.com/*",
    "https://www.futnext.com/*",
    "https://fut.to/*"
  ],
  "background": {
    "service_worker": "src/background.cjs"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ea.com/ea-sports-fc/ultimate-team/web-app/*",
        "https://www.easports.com/*/ea-sports-fc/ultimate-team/web-app/*",
        "https://www.ea.com/*/ea-sports-fc/ultimate-team/web-app/*",
        "https://www.easysbc.io/evolutions*",
        "https://www.futbin.com/*",
        "https://www.fut.gg/*"
      ],
      "js": ["src/content-bridge.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/lodash.min.js",
        "src/page-runtime.js",
        "src/userscript.js"
      ],
      "matches": [
        "https://www.ea.com/*",
        "https://www.easports.com/*",
        "https://www.easysbc.io/*",
        "https://www.futbin.com/*",
        "https://www.fut.gg/*"
      ]
    }
  ]
}
